<?xml version="1.0" encoding="utf-8" ?>
<ContentPage xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
             xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
             x:Class="SicilyLinesMobile.DashboardPage"
             ControlTemplate="{StaticResource MarineLayout}">

    <ContentPage.ToolbarItems>
        <ToolbarItem
                    Text="Déconnexion"
                    Order="Primary"
                    Priority="0"
                    Clicked="OnDeconnexionClicked" />
    </ContentPage.ToolbarItems>

    <Grid>

        <Border StrokeShape="RoundRectangle 20"
                HeightRequest="250"
                BackgroundColor="White"
                Margin="30, 15, 30, 0"
                Padding="20"
                VerticalOptions="Center">

            <VerticalStackLayout Spacing="15">

                <Label Text="Tableau de bord"
                   FontSize="24" 
                   HorizontalOptions="Center" 
                   FontAttributes="Bold"
                   TextColor="Black"/>

                <Button Text="Modifier ses coordonnées"
                    Clicked="OnEditProfileClicked"
                    BackgroundColor="DarkBlue"
                    TextColor="White"
                    CornerRadius="10"
                    Margin="0,10,0,0"
                    />

                <Button Text="Lister ses réservations"
                    Clicked="OnReservationsClicked"
                    BackgroundColor="DarkBlue"
                    TextColor="White"
                    CornerRadius="10"
                    Margin="0,10,0,0"
                    />




            </VerticalStackLayout>

            <Border.Shadow>
                <Shadow Brush="Black" Offset="0,0" Radius="10" Opacity="0.2" />
            </Border.Shadow>
        </Border>




    </Grid>


</ContentPage>